.accordo/test-runs.log
packages/hub/off
scripts/edge-fix-profile/
scripts/edge-plain-profile/
scripts/tmp-edge-profile/
scripts/slidev-dom-output.html

# Temp/debug image outputs
tmp/
tmp-*.svg

