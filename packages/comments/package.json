{
  "name": "accordo-comments",
  "displayName": "Accordo IDE Comments",
  "publisher": "accordo",
  "version": "0.1.0",
  "description": "Accordo IDE Comments — spatial commenting on code, diagrams, images, and all Accordo surfaces",
  "categories": ["Other"],
  "extensionKind": ["workspace"],
  "activationEvents": ["onStartupFinished"],
  "extensionDependencies": ["accordo.accordo-bridge"],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "accordo-comments",
          "title": "Accordo Comments",
          "icon": "$(comment-discussion)"
        }
      ]
    },
    "views": {
      "accordo-comments": [
        {
          "id": "accordo-comments-panel",
          "name": "Comments",
          "icon": "$(comment-discussion)",
          "contextualTitle": "Accordo Comments"
        }
      ]
    },
    "commands": [
      { "command": "accordo.commentsPanel.navigateToAnchor", "title": "Go to Comment Location", "icon": "$(go-to-file)" },
      { "command": "accordo.commentsPanel.resolve", "title": "Resolve", "icon": "$(pass)" },
      { "command": "accordo.commentsPanel.reopen", "title": "Reopen", "icon": "$(debug-restart)" },
      { "command": "accordo.commentsPanel.reply", "title": "Reply", "icon": "$(reply)" },
      { "command": "accordo.commentsPanel.delete", "title": "Delete Thread", "icon": "$(trash)" },
      { "command": "accordo.commentsPanel.refresh", "title": "Refresh Comments", "icon": "$(refresh)" },
      { "command": "accordo.commentsPanel.filterByStatus", "title": "Filter by Status", "icon": "$(filter)" },
      { "command": "accordo.commentsPanel.filterByIntent", "title": "Filter by Intent", "icon": "$(filter)" },
      { "command": "accordo.commentsPanel.clearFilters", "title": "Clear Comment Filters", "icon": "$(clear-all)" },
      { "command": "accordo.commentsPanel.groupBy", "title": "Group Comments By", "icon": "$(list-tree)" },
      { "command": "accordo.comments.new", "title": "Accordo: New Comment" },
      { "command": "accordo.comments.resolveThread", "title": "Resolve", "icon": "$(pass)" },
      { "command": "accordo.comments.deleteThread", "title": "Delete Thread", "icon": "$(trash)" },
      { "command": "accordo.comments.deleteComment", "title": "Delete Comment", "icon": "$(trash)" },
      { "command": "accordo.comments.reopenThread", "title": "Reopen", "icon": "$(debug-restart)" },
      { "command": "accordo.comments.resolveFromComment", "title": "Resolve Thread", "icon": "$(pass)" },
      { "command": "accordo.comments.reopenFromComment", "title": "Reopen Thread", "icon": "$(debug-restart)" },
      { "command": "accordo.comments.cleanStale", "title": "Accordo: Clean Stale Comments", "icon": "$(clear-all)" },
      { "command": "accordo.comments.focusInPreview", "title": "Open in Markdown Preview", "icon": "$(open-preview)" }
    ],
    "menus": {
      "comments/commentThread/title": [
        {
          "command": "accordo.comments.resolveThread",
          "group": "navigation",
          "when": "commentController == accordo-comments && commentThread == 'open'"
        },
        {
          "command": "accordo.comments.reopenThread",
          "group": "navigation",
          "when": "commentController == accordo-comments && commentThread == 'resolved'"
        },
        {
          "command": "accordo.comments.deleteThread",
          "group": "navigation",
          "when": "commentController == accordo-comments"
        },
        {
          "command": "accordo.comments.focusInPreview",
          "group": "navigation",
          "when": "commentController == accordo-comments"
        }
      ],
      "view/title": [
        { "command": "accordo.commentsPanel.refresh", "when": "view == accordo-comments-panel", "group": "navigation" },
        { "command": "accordo.commentsPanel.groupBy", "when": "view == accordo-comments-panel", "group": "navigation" },
        { "command": "accordo.commentsPanel.filterByStatus", "when": "view == accordo-comments-panel", "group": "1_filter@1" },
        { "command": "accordo.commentsPanel.filterByIntent", "when": "view == accordo-comments-panel", "group": "1_filter@2" },
        { "command": "accordo.commentsPanel.clearFilters", "when": "view == accordo-comments-panel", "group": "1_filter@3" }
      ],
      "view/item/context": [
        { "command": "accordo.commentsPanel.navigateToAnchor", "when": "view == accordo-comments-panel && viewItem =~ /accordo-thread/", "group": "inline" },
        { "command": "accordo.commentsPanel.resolve", "when": "view == accordo-comments-panel && viewItem =~ /accordo-thread-(open|stale)/", "group": "1_actions@1" },
        { "command": "accordo.commentsPanel.reopen", "when": "view == accordo-comments-panel && viewItem =~ /accordo-thread-resolved/", "group": "1_actions@1" },
        { "command": "accordo.commentsPanel.reply", "when": "view == accordo-comments-panel && viewItem =~ /accordo-thread/", "group": "1_actions@2" },
        { "command": "accordo.commentsPanel.delete", "when": "view == accordo-comments-panel && viewItem =~ /accordo-thread/", "group": "1_actions@3" }
      ],
      "comments/comment/title": [
        {
          "command": "accordo.comments.deleteComment",
          "group": "group@2",
          "when": "commentController == accordo-comments"
        }
      ],
      "comments/comment/context": [
        {
          "command": "accordo.comments.resolveFromComment",
          "group": "1_actions@1",
          "when": "commentController == accordo-comments && commentThread == 'open'"
        },
        {
          "command": "accordo.comments.reopenFromComment",
          "group": "1_actions@1",
          "when": "commentController == accordo-comments && commentThread == 'resolved'"
        },
        {
          "command": "accordo.comments.deleteComment",
          "group": "1_actions@2",
          "when": "commentController == accordo-comments"
        }
      ],
      "comments/commentThread/context": [
        {
          "command": "accordo.comments.new",
          "group": "inline",
          "when": "commentController == accordo-comments && commentThreadIsEmpty"
        },
        {
          "command": "accordo.comments.new",
          "group": "inline",
          "when": "commentController == accordo-comments && !commentThreadIsEmpty"
        }
      ]
    }
  },
  "type": "module",
  "main": "./dist/extension.js",
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist *.tsbuildinfo",
    "package": "vsce package --no-dependencies",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'no lint configured yet'"
  },
  "devDependencies": {
    "@accordo/bridge-types": "workspace:*",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.100.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20",
    "vscode": "^1.100.0"
  },
  "license": "MIT"
}
