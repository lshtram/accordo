{
  "name": "accordo-browser",
  "displayName": "Accordo Browser Relay",
  "publisher": "accordo",
  "version": "0.1.0",
  "description": "Relay browser-extension comments into Accordo MCP tools",
  "categories": [
    "Other"
  ],
  "extensionKind": [
    "workspace"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "extensionDependencies": [
    "accordo.accordo-bridge",
    "accordo.accordo-comments"
  ],
  "engines": {
    "node": ">=20",
    "vscode": "^1.100.0"
  },
  "type": "module",
  "main": "./dist/extension.js",
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist *.tsbuildinfo",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'no lint configured yet'"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.100.0",
    "@types/ws": "^8.18.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@accordo/bridge-types": "workspace:*",
    "ws": "^8.18.0"
  }
}
