{
  "name": "accordo-slidev",
  "displayName": "Accordo Presentations",
  "publisher": "accordo",
  "version": "0.1.0",
  "description": "Accordo Presentations — agent-controlled Slidev decks with comment SDK integration",
  "categories": ["Other"],
  "extensionKind": ["workspace"],
  "activationEvents": ["onStartupFinished"],
  "extensionDependencies": [
    "accordo.accordo-bridge",
    "accordo.accordo-comments"
  ],
  "contributes": {
    "commands": [
      {
        "command": "accordo.presentation.open",
        "title": "Accordo: Open Presentation"
      },
      {
        "command": "accordo.presentation.close",
        "title": "Accordo: Close Presentation"
      },
      {
        "command": "accordo.presentation.goto",
        "title": "Accordo: Go to Slide"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "accordo.presentation.open",
          "when": "resourceExtname == .md",
          "group": "navigation@100"
        }
      ]
    },
    "customEditors": [
      {
        "viewType": "accordo.deckPresentation",
        "displayName": "Accordo Presentation",
        "selector": [
          { "filenamePattern": "*.deck.md" }
        ],
        "priority": "default"
      }
    ],
    "languages": [
      {
        "id": "slidev-deck",
        "extensions": [".deck.md"],
        "aliases": ["Slidev Deck"],
        "configuration": ""
      }
    ],
    "configuration": {
      "title": "Accordo Presentations",
      "properties": {
        "accordo.presentation.port": {
          "type": "number",
          "default": null,
          "description": "Fixed port for the Slidev dev server. When null, a free port in the range 7788–7888 is selected automatically."
        }
      }
    }
  },
  "type": "module",
  "main": "./dist/extension.js",
  "engines": { "vscode": "^1.100.0" },
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist *.tsbuildinfo",
    "package": "vsce package --no-dependencies",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'no lint configured yet'"
  },
  "devDependencies": {
    "@accordo/bridge-types": "workspace:*",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.100.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
