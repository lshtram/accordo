{
  "name": "@accordo/bridge-types",
  "version": "0.1.0",
  "description": "Shared TypeScript type definitions for Accordo IDE",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
