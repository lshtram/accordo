{
  "name": "accordo-script",
  "displayName": "Accordo IDE Script",
  "publisher": "accordo",
  "version": "0.1.0",
  "description": "Accordo IDE Script — execute multi-step scripted walkthroughs via MCP",
  "categories": [
    "Other"
  ],
  "extensionKind": [
    "workspace"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "extensionDependencies": [
    "accordo.accordo-bridge"
  ],
  "engines": {
    "node": ">=20",
    "vscode": "^1.100.0"
  },
  "type": "module",
  "main": "./dist/extension.js",
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist *.tsbuildinfo",
    "package": "vsce package --no-dependencies",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest watch",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'no lint configured yet'"
  },
  "contributes": {
    "commands": [
      {
        "command": "accordo.script.stop",
        "title": "Accordo Script: Stop Running Script",
        "category": "Accordo"
      }
    ]
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.100.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@accordo/bridge-types": "workspace:*"
  }
}
