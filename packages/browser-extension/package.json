{
  "name": "browser-extension",
  "version": "0.1.0",
  "description": "Accordo Comments — standalone Chrome Manifest V3 browser extension",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest watch",
    "typecheck": "tsc --noEmit",
    "build": "tsx scripts/build.ts",
    "build:watch": "tsx scripts/build.ts --watch",
    "lint": "eslint src/content/semantic-graph-*.ts"
  },
  "devDependencies": {
    "@esbuild/win32-x64": "^0.27.4",
    "@types/chrome": "^0.0.320",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "esbuild": "^0.24.2",
    "eslint": "^10.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@accordo/comment-sdk": "workspace:*"
  },
  "engines": {
    "node": ">=20",
    "vscode": "^1.100.0"
  }
}
