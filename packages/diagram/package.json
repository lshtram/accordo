{
  "name": "accordo-diagram",
  "displayName": "Accordo IDE Diagram Tools",
  "publisher": "accordo",
  "version": "0.1.0",
  "description": "Accordo IDE Diagram Tools — spatial diagram editing with Mermaid + Excalidraw",
  "categories": ["Other"],
  "extensionKind": ["workspace"],
  "activationEvents": ["onStartupFinished"],
  "extensionDependencies": ["accordo.accordo-bridge"],
  "type": "module",
  "main": "./dist/extension.js",
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist *.tsbuildinfo",
    "package": "vsce package --no-dependencies",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'no lint configured yet'"
  },
  "dependencies": {
    "mermaid": "^11.12.3",
    "@dagrejs/dagre": "^1.1.4"
  },
  "devDependencies": {
    "@accordo/bridge-types": "workspace:*",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.100.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20",
    "vscode": "^1.100.0"
  }
}
