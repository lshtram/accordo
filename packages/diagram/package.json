{
  "name": "accordo-diagram",
  "displayName": "Accordo IDE Diagram Tools",
  "publisher": "accordo",
  "version": "0.1.0",
  "description": "Accordo IDE Diagram Tools — spatial diagram editing with Mermaid + Excalidraw",
  "categories": [
    "Other"
  ],
  "extensionKind": [
    "workspace"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "extensionDependencies": [
    "accordo.accordo-bridge"
  ],
  "type": "module",
  "main": "./dist/extension.js",
  "scripts": {
    "build": "tsc -b && pnpm build:webview && node scripts/copy-excalidraw-assets.mjs",
    "build:host": "tsc -b",
    "build:webview": "esbuild src/webview/webview.ts --bundle --outfile=dist/webview/webview.bundle.js --platform=browser --format=iife --target=es2020 --jsx=automatic --jsx-import-source=react --minify --sourcemap --define:process.env.IS_PREACT='\"false\"' --define:process.env.NODE_ENV='\"production\"'",
    "clean": "rm -rf dist *.tsbuildinfo",
    "package": "vsce package --no-dependencies",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:modularity": "vitest run --config vitest.modularity.config.ts",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.webview.json --noEmit",
    "typecheck:webview": "tsc -p tsconfig.webview.json --noEmit",
    "lint": "echo 'no lint configured yet'"
  },
  "dependencies": {
    "@accordo/capabilities": "workspace:*",
    "@accordo/comment-sdk": "workspace:*",
    "@dagrejs/dagre": "^1.1.4",
    "@excalidraw/excalidraw": "0.17.6",
    "@excalidraw/mermaid-to-excalidraw": "^2.2.2",
    "happy-dom": "^20.9.0",
    "jsdom": "^26.1.0",
    "mermaid": "11.12.3",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@accordo/bridge-types": "workspace:*",
    "@types/node": "^20.0.0",
    "@types/react": "18.3.28",
    "@types/react-dom": "18.3.7",
    "@types/vscode": "^1.100.0",
    "esbuild": "^0.27.4",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "contributes": {
    "customEditors": [
      {
        "viewType": "accordo-diagram.diagramEditor",
        "displayName": "Accordo Diagram",
        "selector": [
          {
            "filenamePattern": "*.mmd"
          }
        ],
        "priority": "default"
      }
    ],
    "commands": [
      {
        "command": "accordo-diagram.open",
        "title": "Accordo: Open Diagram"
      },
      {
        "command": "accordo-diagram.newCanvas",
        "title": "Accordo: New Blank Canvas"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "accordo-diagram.open",
          "when": "resourceExtname == .mmd",
          "group": "navigation"
        }
      ]
    }
  },
  "engines": {
    "node": ">=20",
    "vscode": "^1.100.0"
  }
}
