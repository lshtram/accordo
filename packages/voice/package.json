{
  "name": "accordo-voice",
  "displayName": "Accordo IDE Voice",
  "publisher": "accordo",
  "version": "0.1.0",
  "description": "Accordo IDE Voice — TTS read-aloud via external HTTP TTS (preferred) or Kokoro ONNX (fallback)",
  "categories": [
    "Other"
  ],
  "extensionKind": [
    "workspace"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "extensionDependencies": [
    "accordo.accordo-bridge"
  ],
  "engines": {
    "node": ">=20",
    "vscode": "^1.100.0"
  },
  "type": "module",
  "main": "./dist/extension.js",
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist *.tsbuildinfo",
    "package": "vsce package --no-dependencies",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'no lint configured yet'"
  },
  "contributes": {
    "commands": [
      {
        "command": "accordo.voice.readAloud",
        "title": "Read Selection Aloud",
        "icon": "$(play)"
      },
      {
        "command": "accordo.voice.stopNarration",
        "title": "Stop Narration",
        "icon": "$(debug-stop)"
      }
    ],
    "keybindings": [
      {
        "command": "accordo.voice.readAloud",
        "key": "ctrl+alt+r",
        "mac": "cmd+alt+r",
        "when": "editorTextFocus && editorHasSelection"
      }
    ],
    "configuration": {
      "title": "Accordo Voice",
      "properties": {
        "accordo.voice.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable voice session when TTS provider is available"
        },
        "accordo.voice.voice": {
          "type": "string",
          "default": "af_sarah",
          "enum": [
            "af_sarah",
            "am_adam",
            "af_bella",
            "af_nicole",
            "am_michael",
            "bf_emma",
            "bm_george"
          ],
          "description": "Kokoro TTS voice"
        },
        "accordo.voice.speed": {
          "type": "number",
          "default": 1,
          "minimum": 0.5,
          "maximum": 2,
          "description": "TTS playback speed multiplier"
        },
        "accordo.voice.language": {
          "type": "string",
          "default": "en-US",
          "description": "BCP-47 language code for TTS"
        },
        "accordo.voice.narrationMode": {
          "type": "string",
          "default": "narrate-off",
          "enum": [
            "narrate-off",
            "narrate-everything",
            "narrate-summary"
          ],
          "description": "Default narration mode"
        },
        "accordo.voice.ttsEndpoint": {
          "type": "string",
          "default": "",
          "description": "External TTS HTTP endpoint (e.g. https://api.openai.com/v1). When set, this takes priority over local Kokoro."
        },
        "accordo.voice.ttsAuthToken": {
          "type": "string",
          "default": "",
          "description": "Authorization token for external TTS endpoint (Bearer token)"
        },
        "accordo.voice.ttsModel": {
          "type": "string",
          "default": "",
          "description": "Model name for external TTS (e.g. tts-1). Defaults to provider default."
        }
      }
    }
  },
  "devDependencies": {
    "@accordo/bridge-types": "workspace:*",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.100.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "kokoro-js": "1.2.1"
  }
}
