{
  "name": "accordo-voice",
  "displayName": "Accordo IDE Voice",
  "publisher": "accordo",
  "version": "0.1.0",
  "description": "Accordo IDE Voice — local STT/TTS narration and dictation via Whisper.cpp + Kokoro",
  "categories": [
    "Other"
  ],
  "extensionKind": [
    "workspace"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "extensionDependencies": [
    "accordo.accordo-bridge"
  ],
  "engines": {
    "node": ">=20",
    "vscode": "^1.100.0"
  },
  "type": "module",
  "main": "./dist/extension.js",
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist *.tsbuildinfo",
    "package": "vsce package --no-dependencies",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'no lint configured yet'"
  },
  "contributes": {
    "viewsContainers": {
      "panel": [
        {
          "id": "accordo-voice-container",
          "title": "Voice",
          "icon": "$(unmute)"
        }
      ]
    },
    "views": {
      "accordo-voice-container": [
        {
          "id": "accordo-voice-panel",
          "name": "Voice",
          "type": "webview",
          "contextualTitle": "Accordo Voice"
        }
      ]
    },
    "commands": [
      {
        "command": "accordo.voice.startDictation",
        "title": "Start Dictation",
        "icon": "$(record)"
      },
      {
        "command": "accordo.voice.readAloud",
        "title": "Read Selection Aloud",
        "icon": "$(play)"
      },
      {
        "command": "accordo.voice.testTts",
        "title": "Test TTS (Smoke Test)",
        "icon": "$(megaphone)"
      },
      {
        "command": "accordo.voice.testStt",
        "title": "Test STT (Smoke Test)",
        "icon": "$(pulse)"
      },
      {
        "command": "accordo.voice.stopNarration",
        "title": "Stop Narration",
        "icon": "$(debug-stop)"
      },
      {
        "command": "accordo.voice.pauseNarration",
        "title": "Pause Narration",
        "icon": "$(debug-pause)"
      },
      {
        "command": "accordo.voice.resumeNarration",
        "title": "Resume Narration",
        "icon": "$(play)"
      },
      {
        "command": "accordo.voice.configure",
        "title": "Configure Voice",
        "icon": "$(gear)"
      }
    ],
    "keybindings": [
      {
        "command": "accordo.voice.startDictation",
        "key": "ctrl+m",
        "mac": "ctrl+m"
      },
      {
        "command": "accordo.voice.readAloud",
        "key": "ctrl+alt+r",
        "mac": "ctrl+alt+r",
        "when": "editorTextFocus && editorHasSelection"
      },
      {
        "command": "accordo.voice.stopNarration",
        "key": "escape",
        "when": "accordo.voice.narrating"
      }
    ],
    "configuration": {
      "title": "Accordo Voice",
      "properties": {
        "accordo.voice.whisperPath": {
          "type": "string",
          "default": "whisper",
          "description": "Path to whisper.cpp binary. On macOS: `brew install whisper-cpp` then set to `whisper-cpp`. On Windows: download from https://github.com/ggerganov/whisper.cpp/releases or `scoop install whisper-cpp`, then set to the full path or bare name if it's on PATH. On Linux: build from source or use your package manager."
        },
        "accordo.voice.whisperModelFolder": {
          "type": "string",
          "default": "",
          "description": "Directory containing whisper.cpp model files (.bin). Leave empty to auto-discover from common locations. On Windows try %APPDATA%\\whisper\\models; on macOS/Linux try ~/.whisper/models."
        },
        "accordo.voice.whisperModel": {
          "type": "string",
          "default": "ggml-base.en.bin",
          "description": "Whisper model filename"
        },
        "accordo.voice.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable voice session when providers are available"
        },
        "accordo.voice.inputTarget": {
          "type": "string",
          "default": "focus-text-input",
          "enum": [
            "focus-text-input",
            "agent-conversation"
          ],
          "markdownEnumDescriptions": [
            "Insert transcript into the currently focused text input.",
            "Focus the agent chat conversation input and insert transcript there."
          ],
          "description": "Where dictation transcripts should be inserted"
        },
        "accordo.voice.recordingReadyChime": {
          "type": "boolean",
          "default": false,
          "description": "Play a short ready chime when the microphone is prepared and recording is about to start"
        },
        "accordo.voice.voice": {
          "type": "string",
          "default": "af_sarah",
          "enum": [
            "af_sarah",
            "am_adam",
            "af_bella",
            "af_nicole",
            "am_michael",
            "bf_emma",
            "bm_george"
          ],
          "description": "Kokoro TTS voice"
        },
        "accordo.voice.speed": {
          "type": "number",
          "default": 1,
          "minimum": 0.5,
          "maximum": 2,
          "description": "TTS playback speed multiplier"
        },
        "accordo.voice.language": {
          "type": "string",
          "default": "en-US",
          "description": "BCP-47 language code for STT/TTS"
        },
        "accordo.voice.narrationMode": {
          "type": "string",
          "default": "narrate-off",
          "enum": [
            "narrate-off",
            "narrate-everything",
            "narrate-summary"
          ],
          "description": "Default narration mode"
        }
      }
    }
  },
  "devDependencies": {
    "@accordo/bridge-types": "workspace:*",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.100.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "kokoro-js": "1.2.1",
    "sherpa-onnx-node": "1.12.28"
  }
}
