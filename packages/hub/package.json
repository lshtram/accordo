{
  "name": "accordo-hub",
  "version": "0.1.0",
  "description": "Accordo IDE Hub — editor-agnostic MCP server with WebSocket bridge",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "accordo-hub": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist *.tsbuildinfo",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@accordo/bridge-types": "workspace:*",
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^10.1.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
