{
  "name": "accordo-ide",
  "private": true,
  "version": "0.1.0",
  "description": "AI-native development environment — VSCode extension layer",
  "scripts": {
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "test:watch": "pnpm -r run test:watch",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck",
    "clean": "pnpm -r run clean",
    "check": "pnpm build && pnpm test",
    "setup:hooks": "git config core.hooksPath scripts/git-hooks"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  }
}
